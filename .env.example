# PostgreSQL Verbindung
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/business_suite?schema=public"

# Session Secret (für Cookie-Signierung) - in Produktion zufällig generieren!
AUTH_SECRET="change-me-to-a-long-random-string"

# Standard Admin (nur für Seed)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="admin1234"

# E-Mail (Nachbestell-Aufforderungen via Resend) - optional
# Ohne RESEND_API_KEY werden Mails nur geloggt, nicht versendet.
RESEND_API_KEY=""
MAIL_FROM="BusinessSuite <onboarding@resend.dev>"
