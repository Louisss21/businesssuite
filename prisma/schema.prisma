// ============================================================================
//  Business Suite – Prisma Schema
//  Monolithisches MVP, bewusst ERP-/Shop-erweiterbar modelliert.
//  Geldbeträge: Decimal(12,2). Steuersätze: Decimal(5,2) (z.B. 19.00).
//  DATEV-Ready: Netto / Steuer / Brutto getrennt, eindeutige Belegnummern,
//  vollständige Kundenstammdaten, Periodenzuordnung pro Rechnung.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
//  Enums
// ----------------------------------------------------------------------------

enum UserRole {
  ADMIN
  MEMBER
}

enum CustomerType {
  COMPANY // Firmenkunde
  PRIVATE // Privatkunde
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
  WON
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  OPEN
  PAID
  OVERDUE
}

// ----------------------------------------------------------------------------
//  Auth / Users
// ----------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(MEMBER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

// ----------------------------------------------------------------------------
//  CRM
// ----------------------------------------------------------------------------

model Customer {
  id   String       @id @default(cuid())
  type CustomerType @default(COMPANY)

  // Firmenkunde
  companyName String?

  // Privatkunde / Hauptkontakt
  firstName String?
  lastName  String?

  email String?
  phone String?

  // Adresse (vollständig für Rechnung / DATEV)
  street     String?
  postalCode String?
  city       String?
  country    String? @default("DE")

  // Steuerliche Daten
  vatId     String? // USt-IdNr.
  taxNumber String? // Steuernummer

  notes String?

  contacts ContactPerson[]
  leads    Lead[]
  orders   Order[]
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@map("customers")
}

model ContactPerson {
  id         String  @id @default(cuid())
  customerId String
  firstName  String
  lastName   String
  email      String?
  phone      String?
  position   String?
  isPrimary  Boolean @default(false)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@map("contact_persons")
}

model Lead {
  id     String     @id @default(cuid())
  title  String
  status LeadStatus @default(NEW)
  notes  String?

  // Optionaler Bezug zu einem bestehenden Kunden
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([customerId])
  @@map("leads")
}

// ----------------------------------------------------------------------------
//  Orders (manuell)
// ----------------------------------------------------------------------------

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique // z.B. ORD-2026-0001
  customerId  String
  status      OrderStatus @default(DRAFT)
  notes       String?

  // Summen (denormalisiert für schnelle Listen/Reports)
  netTotal   Decimal @default(0) @db.Decimal(12, 2)
  taxTotal   Decimal @default(0) @db.Decimal(12, 2)
  grossTotal Decimal @default(0) @db.Decimal(12, 2)

  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items    OrderItem[]
  invoice  Invoice? // genau eine Rechnung je Bestellung

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  productName String // frei, noch kein Produktkatalog
  quantity    Decimal @default(1) @db.Decimal(12, 3)
  unitPrice   Decimal @db.Decimal(12, 2) // Nettopreis pro Einheit
  taxRate     Decimal @default(19) @db.Decimal(5, 2)

  // Berechnete Beträge (getrennt für DATEV)
  netAmount   Decimal @db.Decimal(12, 2)
  taxAmount   Decimal @db.Decimal(12, 2)
  grossAmount Decimal @db.Decimal(12, 2)

  sortOrder Int @default(0)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

// ----------------------------------------------------------------------------
//  Invoices
// ----------------------------------------------------------------------------

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique // z.B. INV-2026-0001
  status        InvoiceStatus @default(OPEN)

  customerId String
  orderId    String? @unique // 1:1 zu Order (optional, falls manuell)

  issueDate DateTime  @default(now())
  dueDate   DateTime
  paidAt    DateTime?

  // Summen (getrennt für DATEV / Reporting)
  netTotal   Decimal @default(0) @db.Decimal(12, 2)
  taxTotal   Decimal @default(0) @db.Decimal(12, 2)
  grossTotal Decimal @default(0) @db.Decimal(12, 2)

  // Buchhaltungsperiode (Monat/Quartal/Jahr) – Pflichtzuordnung
  accountingPeriodId String

  customer         Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  order            Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  accountingPeriod AccountingPeriod @relation(fields: [accountingPeriodId], references: [id], onDelete: Restrict)
  items            InvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([accountingPeriodId])
  @@index([issueDate])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  productName String
  quantity    Decimal @default(1) @db.Decimal(12, 3)
  unitPrice   Decimal @db.Decimal(12, 2)
  taxRate     Decimal @default(19) @db.Decimal(5, 2)

  netAmount   Decimal @db.Decimal(12, 2)
  taxAmount   Decimal @db.Decimal(12, 2)
  grossAmount Decimal @db.Decimal(12, 2)

  sortOrder Int @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

// ----------------------------------------------------------------------------
//  Buchhaltungs-Periode (logische Ordnerstruktur Jahr/Quartal/Monat)
// ----------------------------------------------------------------------------

model AccountingPeriod {
  id      String @id @default(cuid())
  year    Int
  month   Int // 1..12
  quarter Int // 1..4 (abgeleitet aus month)
  label   String // z.B. "01_Januar 2026"

  invoices Invoice[]

  createdAt DateTime @default(now())

  @@unique([year, month])
  @@index([year])
  @@index([year, quarter])
  @@map("accounting_periods")
}

// ----------------------------------------------------------------------------
//  Belegnummern-Sequenzen (pro Scope + Jahr eindeutig fortlaufend)
// ----------------------------------------------------------------------------

model NumberSequence {
  id    String @id @default(cuid())
  scope String // "invoice" | "order"
  year  Int
  value Int    @default(0)

  @@unique([scope, year])
  @@map("number_sequences")
}

// ----------------------------------------------------------------------------
//  Stammdaten / Settings (Singleton)
// ----------------------------------------------------------------------------

model CompanySettings {
  id String @id @default("singleton")

  companyName String  @default("")
  street      String  @default("")
  postalCode  String  @default("")
  city        String  @default("")
  country     String  @default("DE")
  email       String  @default("")
  phone       String  @default("")
  taxNumber   String  @default("")
  vatId       String  @default("")

  // Rechnungs-Einstellungen
  invoiceNumberFormat   String  @default("INV-{YYYY}-{SEQ:4}")
  orderNumberFormat     String  @default("ORD-{YYYY}-{SEQ:4}")
  defaultPaymentTermDays Int    @default(14)
  defaultTaxRate        Decimal @default(19) @db.Decimal(5, 2)

  updatedAt DateTime @updatedAt

  @@map("company_settings")
}
